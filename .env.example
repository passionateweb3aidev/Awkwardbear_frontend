# ============================================
# 环境配置
# ============================================

# 环境类型: "production" 或 "test"
# 默认值: production
# - production: 生产环境 (www.awkwardbear.com)
# - test: 测试环境 (www.test.awkwardbear.com)
NEXT_PUBLIC_ENVIRONMENT=production

# ============================================
# 高级配置（可选）
# ============================================

# API 基础地址（可选）
# 如果设置，将覆盖根据 NEXT_PUBLIC_ENVIRONMENT 自动推导的值
# 适用场景：本地开发、特殊部署环境
# NEXT_PUBLIC_API_BASE_URL=https://custom-api.example.com

# 邀请链接域名（可选）
# 如果设置，将覆盖根据 NEXT_PUBLIC_ENVIRONMENT 自动推导的值
# 适用场景：自定义域名、CDN 域名
# NEXT_PUBLIC_INVITE_LINK_DOMAIN=https://custom-domain.example.com

# ============================================
# 其他配置
# ============================================

# WalletConnect Project ID（必需）
NEXT_PUBLIC_WAGMI_PROJECT_ID=64822f3f7973c800b39414924fbbd66a

# Google Analytics 4 ID（可选）
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# 高级签到（SUPPER_CHECK_IN）BNB 转账配置（可选）
# 固定收款地址（BSC 地址），例如：0x1234...
NEXT_PUBLIC_SUPPER_CHECK_IN_TO=0x0000000000000000000000000000000000000000
# 固定转账数量（单位 BNB，例如 0.01）
NEXT_PUBLIC_SUPPER_CHECK_IN_AMOUNT=0.01

# ============================================
# 环境配置示例
# ============================================

# 生产环境配置示例:
# NEXT_PUBLIC_ENVIRONMENT=production
# NEXT_PUBLIC_WAGMI_PROJECT_ID=your_production_project_id

# 测试环境配置示例:
# NEXT_PUBLIC_ENVIRONMENT=test
# NEXT_PUBLIC_WAGMI_PROJECT_ID=your_test_project_id

# 本地开发配置示例（连接到测试后端）:
# NEXT_PUBLIC_ENVIRONMENT=test
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# NEXT_PUBLIC_WAGMI_PROJECT_ID=your_dev_project_id
